# MedServicePrice.kz — environment template. Copy to web/.env.local and worker/.env.
# NEVER commit real keys. The example holds placeholders only.

# --- Supabase (shared) ---
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# Publishable / anon key — safe for the browser.
SUPABASE_ANON_KEY=sb_publishable_xxx
# Secret / service_role key — SERVER + WORKER ONLY. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# --- web/.env.local (Next.js needs the NEXT_PUBLIC_ prefix for browser vars) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# --- Worker (Phase 2) ---
# Polling interval for the parse_runs job queue (seconds).
WORKER_POLL_INTERVAL=10
# Single FX rate: worker converts USD -> KZT on write (price is always KZT).
FX_USD_KZT=470
# LLM key + model for the extraction stage (Anthropic).
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Supabase Management API (used to apply migrations over HTTPS) ---
# Personal access token from https://supabase.com/dashboard/account/tokens (sbp_...).
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=YOUR-PROJECT-ref
